---
import BaseLayout from '@layouts/BaseLayout.astro';
import QuestionCard from '@components/QuestionCard.astro';
import CityCard from '@components/CityCard.astro';

// TODO: sau này data này sẽ đến từ Content Collections
// Hiện tại hardcode để match với home.html mẫu
const popularQuestions = [
  {
    href: '/hoi-an/must-try-dishes/',
    category: 'Food',
    city: 'Hoi An',
    readingTime: 6,
    title: 'What are the must-try dishes in Hoi An?',
    preview: "Five dishes define Hoi An's table: Cao Lầu, the town's signature noodle; Bánh Mì Phượng, made famous by Bourdain; white rose dumplings; Mì Quảng; and Cơm Gà…",
  },
  {
    href: '/hanoi/hanoi-to-sapa/',
    category: 'Transport',
    city: 'Hanoi',
    readingTime: 4,
    title: 'How do I get from Hanoi to Sapa in 2026?',
    preview: 'The overnight sleeper bus is the most practical option — eight hours door to door, around 350,000 VND. The train stops short of Sapa itself…',
  },
  {
    href: '/central/best-month-to-visit/',
    category: 'Weather',
    city: 'Central coast',
    readingTime: 3,
    title: 'When is the best month to visit central Vietnam?',
    preview: 'February through May is the honest answer. Skies are dry, the rivers low, and the evenings in Hoi An warm enough for a linen shirt…',
  },
  {
    href: '/ho-chi-minh/bargaining-etiquette/',
    category: 'Culture',
    city: 'Ho Chi Minh',
    readingTime: 7,
    title: 'Is it rude to bargain in Saigon markets?',
    preview: 'Not at Bến Thành — bargaining is expected, and vendors build it into their asking price. At a neighborhood market the rules change…',
  },
  {
    href: '/vietnam/motorbike-safety/',
    category: 'Safety',
    city: 'Nationwide',
    readingTime: 5,
    title: 'Is renting a motorbike in Vietnam safe?',
    preview: 'The short answer: safer than its reputation, but not casually safe. Outside the big cities traffic calms quickly, and coastal loops like Hải Vân…',
  },
  {
    href: '/vietnam/daily-budget/',
    category: 'Budget',
    city: 'Nationwide',
    readingTime: 5,
    title: 'What does a realistic daily budget look like?',
    preview: "Backpacker: 650,000 VND. Mid-range: 1.8 million. Comfortable but not extravagant: 3.2 million. The jumps are sharper than you'd think…",
  },
];

const cities = [
  { name: 'Hanoi', region: 'North · Capital', questionCount: 54, href: '/cities/hanoi/' },
  { name: 'Ho Chi Minh', region: 'South · Metropolis', questionCount: 67, href: '/cities/ho-chi-minh/' },
  { name: 'Hoi An', region: 'Central · UNESCO', questionCount: 48, href: '/cities/hoi-an/', featured: true },
  { name: 'Da Nang', region: 'Central · Coast', questionCount: 31, href: '/cities/da-nang/' },
  { name: 'Sapa', region: 'Northwest · Highlands', questionCount: 22, href: '/cities/sapa/' },
  { name: 'Hue', region: 'Central · Imperial', questionCount: 19, href: '/cities/hue/' },
  { name: 'Phu Quoc', region: 'Island · South', questionCount: 27, href: '/cities/phu-quoc/' },
  { name: 'Nha Trang', region: 'Coast · Resort', questionCount: 18, href: '/cities/nha-trang/' },
];

const recentAnswers = [
  { date: 'Apr 21', category: 'Transport', city: 'Hanoi', title: 'Which district should I stay in for a first trip to Hanoi?', readingTime: 4, href: '/hanoi/best-district-first-trip/' },
  { date: 'Apr 19', category: 'Food', city: 'Ho Chi Minh', title: 'Where do locals eat bánh xèo in Saigon (not the tourist version)?', readingTime: 5, href: '/ho-chi-minh/local-banh-xeo/' },
  { date: 'Apr 17', category: 'Planning', city: 'Nationwide', title: 'Is two weeks enough time to see Vietnam end to end?', readingTime: 8, href: '/vietnam/two-weeks-itinerary/' },
  { date: 'Apr 14', category: 'Culture', city: 'Hue', title: 'What should I know before visiting the Imperial City?', readingTime: 6, href: '/hue/imperial-city/' },
  { date: 'Apr 12', category: 'Budget', city: 'Phu Quoc', title: 'Is Phu Quoc more expensive than the mainland?', readingTime: 4, href: '/phu-quoc/cost-vs-mainland/' },
];
---

<BaseLayout
  title="Pholio — Real answers from locals about traveling Vietnam."
  description="An editorial Q&A about traveling Vietnam. Specific questions, specific answers, written by people who actually live there."
  lang="en"
  schemaType="WebSite"
  keywords={['Vietnam travel', 'travel Q&A', 'Hoi An guide', 'Hanoi travel', 'local travel advice']}
>
  {/* Hero */}
  <section class="max-page" style="padding-top:96px;padding-bottom:96px">
    <div style="max-width:960px">
      <div class="eyebrow" style="margin-bottom:24px">An editorial Q&amp;A · Vietnam travel</div>
      <h1 class="hero-h1">Real answers from locals<br/>about traveling <em>Vietnam.</em></h1>
      <p class="muted" style="margin-top:32px;max-width:560px;font-size:19px;line-height:1.6">
        Specific questions, specific answers. No listicles, no content farms — just editorial guidance from people who actually live there.
      </p>
    </div>

    <div style="margin-top:56px;max-width:780px">
      <form action="/search/" method="get" class="search-wrap" role="search">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="7"/>
          <path d="m20 20-3.5-3.5"/>
        </svg>
        <input
          type="search"
          name="q"
          class="search-input"
          placeholder="Ask anything about Vietnam travel…"
          aria-label="Search questions"
        />
        <span class="mono muted" style="font-size:11px;white-space:nowrap">
          <span style="padding:3px 8px;border:1px solid var(--borderS);border-radius:4px">⏎</span> Ask
        </span>
      </form>
      <div style="margin-top:24px;display:flex;flex-wrap:wrap;gap:10px;align-items:center">
        <span class="eyebrow" style="margin-right:8px">Try —</span>
        <a href="/hoi-an/best-time-to-visit/" class="chip">Best time to visit Hoi An</a>
        <a href="/hanoi/hanoi-to-sapa/" class="chip">How to get from Hanoi to Sapa</a>
        <a href="/phu-quoc/october-visit/" class="chip">Is Phu Quoc worth it in October?</a>
        <a href="/ho-chi-minh/district-1-food/" class="chip">Where to eat in District 1</a>
        <a href="/da-nang/safe-cafes/" class="chip">Safe cafés in Da Nang</a>
      </div>
    </div>
  </section>

  <div class="rule"></div>

  {/* Popular Questions */}
  <section class="max-page sec">
    <div class="sec-head" style="display:flex;align-items:flex-end;justify-content:space-between;gap:32px;flex-wrap:wrap">
      <div>
        <div class="eyebrow" style="margin-bottom:16px">§ 01 · Popular questions</div>
        <h2 class="display-h2">The ones everyone asks,<br/><em class="muted">answered properly.</em></h2>
      </div>
      <a href="/questions/" class="ulink" style="font-size:14px">See all 312 questions →</a>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:0 64px">
      {popularQuestions.map((q) => <QuestionCard {...q} variant="grid" />)}
    </div>
  </section>

  <div class="rule"></div>

  {/* Cities */}
  <section class="max-page sec">
    <div class="sec-head">
      <div class="eyebrow" style="margin-bottom:16px">§ 02 · By city</div>
      <h2 class="display-h2">Eight places, written carefully.</h2>
    </div>
    <div class="city-grid">
      {cities.map((c) => <CityCard {...c} lang="en" />)}
    </div>
  </section>

  <div class="rule"></div>

  {/* App */}
  <section class="max-page sec">
    <div style="display:grid;grid-template-columns:1fr;gap:64px;align-items:center" class="app-grid">
      <div>
        <div class="eyebrow" style="margin-bottom:16px">§ 03 · The app</div>
        <h2 class="display-h2" style="margin-bottom:32px">Save answers.<br/>Take them <em>offline.</em></h2>
        <p class="muted" style="font-size:18px;margin-bottom:24px;max-width:480px">
          The Pholio app turns any answer you've read into an offline guide — maps, addresses, hours, and local notes bundled per city.
        </p>
        <ul style="list-style:none;padding:0;margin:0 0 40px;max-width:480px">
          <li class="hairline-b" style="display:flex;gap:12px;padding:12px 0">
            <span class="mono muted" style="font-size:12px;padding-top:4px">01</span>
            <span>Offline city packs with curated places and routes</span>
          </li>
          <li class="hairline-b" style="display:flex;gap:12px;padding:12px 0">
            <span class="mono muted" style="font-size:12px;padding-top:4px">02</span>
            <span>Ask a local directly when your question isn't answered yet</span>
          </li>
          <li style="display:flex;gap:12px;padding:12px 0">
            <span class="mono muted" style="font-size:12px;padding-top:4px">03</span>
            <span>Translate common travel phrases into Vietnamese, Khmer, Lao</span>
          </li>
        </ul>
        <div style="display:flex;flex-wrap:wrap;gap:12px">
          <a href="/app/" class="store-badge">
            <span style="display:flex;flex-direction:column">
              <span class="sub">Download on the</span>
              <span class="main">App Store</span>
            </span>
          </a>
          <a href="/app/" class="store-badge alt">
            <span style="display:flex;flex-direction:column">
              <span class="sub">Get it on</span>
              <span class="main">Google Play</span>
            </span>
          </a>
        </div>
      </div>
      <div style="display:flex;justify-content:center">
        <div style="width:280px;height:560px;border-radius:40px;border:10px solid var(--ink);background:var(--bg);padding:16px;position:relative">
          <div style="position:absolute;top:8px;left:50%;transform:translateX(-50%);width:96px;height:20px;background:var(--ink);border-radius:999px"></div>
          <div style="height:100%;width:100%;border-radius:24px;overflow:hidden;border:1px solid var(--border);display:flex;flex-direction:column">
            <div class="hairline-b" style="padding:16px">
              <div style="font-family:'Instrument Serif',serif;font-size:20px">Pholio</div>
              <div class="mono muted" style="font-size:10px;margin-top:4px">OFFLINE · HOI AN PACK</div>
            </div>
            <div style="padding:16px;flex:1">
              <div class="acc mono" style="font-size:9px;margin-bottom:4px">FOOD · SAVED</div>
              <div style="font-family:'Instrument Serif',serif;font-size:18px;line-height:1.2;margin-bottom:12px">Must-try dishes in Hoi An</div>
              <div class="ph-stripes" style="height:64px;margin-bottom:12px">[ map.hoian.off ]</div>
              <div class="hairline-t muted" style="padding-top:8px;font-size:10px">5 places · 1.2km walk</div>
              <div class="hairline-t" style="padding-top:8px;margin-top:8px;font-size:11px">
                <div style="font-weight:500">Bánh Mì Phượng</div>
                <div class="muted" style="font-size:10px">2B Phan Châu Trinh · ₫40,000</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="rule"></div>

  {/* Recent answers */}
  <section class="max-page sec">
    <div class="sec-head" style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px">
      <div>
        <div class="eyebrow" style="margin-bottom:16px">§ 04 · Recently answered</div>
        <h2 class="display-h2">Fresh off the desk.</h2>
      </div>
      <a href="/questions/" class="ulink" style="font-size:14px">All recent →</a>
    </div>
    <div style="max-width:900px">
      {recentAnswers.map((q, i) => (
        <QuestionCard
          {...q}
          variant="compact"
          class:list={i === recentAnswers.length - 1 ? ['hairline-b'] : []}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  @media (min-width: 900px) {
    :global(.app-grid) {
      grid-template-columns: 1fr 1fr !important;
    }
  }
</style>
