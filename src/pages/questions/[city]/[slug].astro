---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allQuestions = await getCollection('questions', ({ data, id }) => {
    return !data.draft && id.startsWith('en/');
  });

  return allQuestions.map((entry) => ({
    params: { city: entry.data.city, slug: entry.data.canonicalSlug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'questions'>;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const { data } = entry;

const categoryLabels: Record<string, string> = {
  food: 'Food', transport: 'Transport', culture: 'Culture', weather: 'Weather',
  budget: 'Budget', safety: 'Safety', planning: 'Planning',
  activities: 'Activities', accommodation: 'Stay',
};

// H2 headings for TOC
const tocHeadings = headings.filter((h) => h.depth === 2);

// Related questions same city
const allQuestions = await getCollection('questions', ({ data: d, id }) => {
  return !d.draft && id.startsWith('en/') && d.city === data.city && d.canonicalSlug !== data.canonicalSlug;
});
const related = allQuestions.slice(0, 3);

// Deterministic question number for rail
const questionNum = String(
  Math.abs(data.canonicalSlug.split('').reduce((a, c) => a + c.charCodeAt(0), 0)) % 999
).padStart(3, '0');
---

<BaseLayout
  title={data.title}
  description={data.description}
  lang="en"
  city={data.city}
  canonicalSlug={data.canonicalSlug}
  schemaType="Article"
  pubDate={data.pubDate}
  updatedDate={data.updatedDate}
  author={data.author}
  image={data.heroImage}
  faq={data.faq}
  keywords={data.keywords}
>
  <div class="max-page" style="padding-top:40px">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/">VIETNAM</a>
      <span class="sep">→</span>
      <a href={`/cities/${data.city}/`}>{data.cityDisplay.toUpperCase()}</a>
      <span class="sep">→</span>
      <a href={`/categories/${data.category}/`}>{categoryLabels[data.category].toUpperCase()}</a>
    </nav>
  </div>

  {/* Hidden metadata for Pagefind filters */}
  <div
    data-pagefind-filter={`category:${categoryLabels[data.category]}`}
    data-pagefind-filter-city={data.cityDisplay}
    data-pagefind-meta={`image[src]:${data.heroImage || '/og-default.png'}`}
    style="display:none"
  ></div>

  <div class="max-page art-wrap">
    <aside class="art-rail">
      <div class="eyebrow" style="margin-bottom:12px">Question No.</div>
      <div style="font-family:'Instrument Serif',serif;font-size:64px;line-height:1;color:var(--muted)">{questionNum}</div>
      <div class="eyebrow" style="margin-top:32px;margin-bottom:12px">Filed under</div>
      <div class="tag-list">
        <a href={`/categories/${data.category}/`} class="chip" style="padding:4px 10px;font-size:12px">{categoryLabels[data.category]}</a>
        <a href={`/cities/${data.city}/`} class="chip" style="padding:4px 10px;font-size:12px">{data.cityDisplay}</a>
      </div>
      {data.contributors.length > 0 && (
        <>
          <div class="eyebrow" style="margin-top:32px;margin-bottom:12px">Contributors</div>
          <div style="font-size:13px;line-height:1.6;color:var(--muted)">
            {data.contributors.map((c) => <div>{c}</div>)}
          </div>
        </>
      )}
    </aside>

    <article class="max-prose" style="margin:0 auto;width:100%">
      <header style="margin-bottom:48px">
        <h1 style="font-size:clamp(40px,6vw,64px);line-height:1.05;letter-spacing:-.02em;margin-bottom:32px">
          {data.title}
        </h1>
        <div class="muted hairline-b" style="display:flex;flex-wrap:wrap;gap:8px 24px;align-items:center;font-size:14px;padding-bottom:24px">
          <span>
            {data.updatedDate ? 'Updated ' : 'Published '}
            <time datetime={(data.updatedDate || data.pubDate).toISOString()}>
              {(data.updatedDate || data.pubDate).toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' })}
            </time>
          </span>
          <span style="opacity:.3">·</span>
          <span>{data.readingTime} min read</span>
          {data.contributors.length > 0 && (
            <>
              <span style="opacity:.3">·</span>
              <span style="display:inline-flex;align-items:center;gap:8px">
                <span style="display:flex">
                  <span class="avatar ph-solid-2" style="width:20px;height:20px;border:2px solid var(--bg);margin-right:-6px"></span>
                  <span class="avatar ph-solid-3" style="width:20px;height:20px;border:2px solid var(--bg);margin-right:-6px"></span>
                  <span class="avatar ph-solid-1" style="width:20px;height:20px;border:2px solid var(--bg)"></span>
                </span>
                Contributed by {data.contributors.length} {data.contributors.length === 1 ? 'local' : 'locals'}
              </span>
            </>
          )}
        </div>
      </header>

      <div class="answer-box" style="margin-bottom:56px" aria-label="Quick answer">
        <div class="lbl">Quick Answer</div>
        <p set:html={data.quickAnswer}></p>
        <div style="margin-top:20px;padding-top:20px;border-top:1px solid rgba(194,65,12,.2);display:flex;justify-content:space-between;font-size:12px">
          <span class="mono muted">
            VERIFIED · {(data.updatedDate || data.pubDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).toUpperCase()}
          </span>
          <span class="acc" style="font-weight:500">Read below ↓</span>
        </div>
      </div>

      <div class="prose-ed">
        <Content />
      </div>

      <aside style="margin:64px 0;padding:32px;border-left:4px solid var(--ink);background:var(--warmpaper)">
        <div class="eyebrow" style="margin-bottom:12px">Pholio app</div>
        <p style="font-family:'Instrument Serif',serif;font-size:24px;line-height:1.3;margin:0 0 16px">
          Get an <em>offline guide</em> with locations, prices, and hours in the Pholio app.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:16px;font-size:14px;align-items:center">
          <a href="/app/" class="ulink" style="font-weight:500">iOS →</a>
          <a href="/app/" class="ulink" style="font-weight:500">Android →</a>
          <span class="mono muted" style="font-size:12px">Free · No account needed</span>
        </div>
      </aside>

      {data.faq && data.faq.length > 0 && (
        <section style="margin-top:64px">
          <div class="eyebrow" style="margin-bottom:12px">Also asked</div>
          <h2 style="font-size:36px;line-height:1.1;margin-bottom:32px">Related questions, answered.</h2>
          {data.faq.map((item) => (
            <details>
              <summary>
                <span>{item.q}</span>
                <span class="plus" aria-hidden="true"></span>
              </summary>
              <div class="answer" set:html={item.a}></div>
            </details>
          ))}
        </section>
      )}

      {related.length > 0 && (
        <section style="margin-top:80px">
          <div class="eyebrow" style="margin-bottom:24px">Read next</div>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:24px">
            {related.map((r) => (
              <a href={`/questions/${r.data.city}/${r.data.canonicalSlug}/`} class="hub-card">
                <div class="cat-tag" style="margin-bottom:8px">{categoryLabels[r.data.category]}</div>
                <h3 style="font-size:20px;line-height:1.2">{r.data.title}</h3>
              </a>
            ))}
          </div>
        </section>
      )}
    </article>

    <aside class="art-toc">
      <div style="position:sticky;top:90px" class="toc">
        {tocHeadings.length > 0 && (
          <>
            <div class="eyebrow" style="margin-bottom:16px">On this page</div>
            {tocHeadings.map((h) => (
              <a href={`#${h.slug}`}>{h.text}</a>
            ))}
          </>
        )}
        <div class="hairline-t" style="margin-top:32px;padding-top:16px">
          <a href={`/vi/questions/${data.city}/${data.canonicalSlug}/`} class="ulink-acc" style="font-size:14px">Đọc tiếng Việt →</a>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  .art-wrap {
    padding-top: 32px;
    padding-bottom: 96px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .art-rail,
  .art-toc {
    display: none;
  }
  @media (min-width: 1024px) {
    .art-wrap {
      grid-template-columns: 220px 1fr 220px;
    }
    .art-rail,
    .art-toc {
      display: block;
    }
  }
</style>