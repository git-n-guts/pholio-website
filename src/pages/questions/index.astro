---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const categoryLabels: Record<string, string> = {
  food: 'Food',
  transport: 'Transport',
  culture: 'Culture',
  weather: 'Weather',
  budget: 'Budget',
  safety: 'Safety',
  planning: 'Planning',
  activities: 'Activities',
  accommodation: 'Stay',
};

// Get all published EN questions
const all = await getCollection('questions', ({ data, id }) => {
  return !data.draft && id.startsWith('en/');
});

// Group by first letter of title
const grouped = all.reduce<Record<string, typeof all>>((acc, q) => {
  const firstLetter = q.data.title.charAt(0).toUpperCase();
  if (!acc[firstLetter]) acc[firstLetter] = [];
  acc[firstLetter].push(q);
  return acc;
}, {});

// Sort letters alphabetically
const sortedLetters = Object.keys(grouped).sort();

// Category counts (dummy for display - real counts from collection)
const categories = [
  { slug: 'food', label: 'Food', count: all.filter((q) => q.data.category === 'food').length },
  { slug: 'transport', label: 'Transport', count: all.filter((q) => q.data.category === 'transport').length },
  { slug: 'culture', label: 'Culture', count: all.filter((q) => q.data.category === 'culture').length },
  { slug: 'budget', label: 'Budget', count: all.filter((q) => q.data.category === 'budget').length },
  { slug: 'accommodation', label: 'Stay', count: all.filter((q) => q.data.category === 'accommodation').length },
  { slug: 'safety', label: 'Safety', count: all.filter((q) => q.data.category === 'safety').length },
  { slug: 'weather', label: 'Weather', count: all.filter((q) => q.data.category === 'weather').length },
  { slug: 'planning', label: 'Planning', count: all.filter((q) => q.data.category === 'planning').length },
];
---

<BaseLayout
  title="All questions — Pholio"
  description={`Every answer we've written about traveling Vietnam. Browse all ${all.length} questions by city, category, or alphabetically.`}
  lang="en"
  schemaType="CollectionPage"
>
  <section class="max-page ptitle">
    <nav class="crumb"><a href="/">PHOLIO</a><span class="sep">→</span><span class="cur">QUESTIONS</span></nav>
    <div class="eyebrow" style="margin-top:24px">{all.length} answered · Updated weekly</div>
    <h1 class="hero-h1" style="margin-top:16px">Every question,<br/><em>all the answers.</em></h1>

    <div style="margin-top:48px;max-width:780px">
      <form method="get" action="/search/" role="search">
        <div class="search-wrap">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="11" cy="11" r="7"/>
            <path d="m20 20-3.5-3.5"/>
          </svg>
          <input class="search-input" type="search" name="q" placeholder={`Search ${all.length} questions…`}/>
        </div>
      </form>
    </div>
  </section>

  <section class="max-page hairline-t hairline-b" style="padding:20px 24px;position:sticky;top:68px;background:var(--bg);z-index:30">
    <div style="display:flex;gap:24px;flex-wrap:wrap;align-items:center">
      <div style="display:flex;gap:8px;overflow-x:auto;align-items:center">
        <span class="eyebrow" style="flex-shrink:0">Category</span>
        <button class="tab is-active">All · {all.length}</button>
        {categories.map((c) => (
          c.count > 0 && <a href={`/categories/${c.slug}/`} class="tab">{c.label} · {c.count}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="max-page sec">
    <div style="max-width:1000px">
      {sortedLetters.length === 0 ? (
        <p class="muted" style="padding:48px 0">No questions published yet.</p>
      ) : (
        sortedLetters.map((letter) => (
          <div class="hairline-b letter-row">
            <div class="letter">{letter}</div>
            <div>
              {grouped[letter].map((q, i) => (
                <a
                  href={`/questions/${q.data.city}/${q.data.canonicalSlug}/`}
                  class="q-card"
                  style={i === 0 ? 'padding-top:0;border-top:none' : ''}
                >
                  <div class="meta">
                    <span class="cat-tag">{categoryLabels[q.data.category]}</span>
                    <span class="muted" style="font-size:12px">{q.data.cityDisplay} · {q.data.readingTime} min</span>
                  </div>
                  <h3 style="font-size:22px;line-height:1.2">{q.data.title}</h3>
                </a>
              ))}
            </div>
          </div>
        ))
      )}

      <div style="padding:64px 0;text-align:center">
        <a href="/ask/" class="btn btn-ghost">Can't find your question? Ask →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .letter-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 48px;
    padding: 32px 0;
  }
  .letter {
    font-family: var(--font-heading);
    font-size: 56px;
    line-height: 1;
    color: var(--muted);
  }
</style>
