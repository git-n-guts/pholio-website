---
import BaseLayout from '@layouts/BaseLayout.astro';
import CityCard from '@components/CityCard.astro';

const otherCities = [
  { name: 'Hanoi', region: 'North · Capital', questionCount: 54, href: '/cities/hanoi/' },
  { name: 'Saigon', region: 'South · Metropolis', questionCount: 67, href: '/cities/saigon/' },
  { name: 'Da Nang', region: 'Central · Coast', questionCount: 31, href: '/cities/da-nang/' },
  { name: 'Sapa', region: 'Northwest · Highlands', questionCount: 22, href: '/cities/sapa/' },
  { name: 'Hue', region: 'Central · Imperial', questionCount: 19, href: '/cities/hue/' },
  { name: 'Phu Quoc', region: 'Island · South', questionCount: 27, href: '/cities/phu-quoc/' },
  { name: 'Nha Trang', region: 'Coast · Resort', questionCount: 18, href: '/cities/nha-trang/' },
];

const comingSoon = ['Mai Châu', 'Ninh Bình', 'Ha Giang', 'Con Dao', 'Dalat'];
---

<BaseLayout
  title="Cities — Pholio"
  description="Eight Vietnamese destinations, written carefully. Every city below has a dedicated editorial team answering reader questions."
  lang="en"
  schemaType="CollectionPage"
>
  <section class="max-page ptitle">
    <nav class="crumb"><a href="/">PHOLIO</a><span class="sep">→</span><span class="cur">CITIES</span></nav>
    <div class="eyebrow" style="margin-top:24px">All destinations · 8</div>
    <h1 class="hero-h1" style="margin-top:16px">Eight places,<br/><em>written carefully.</em></h1>
    <p class="muted" style="max-width:560px;margin-top:24px;font-size:18px">Every city below has a dedicated editorial team answering reader questions. Pick where you're going and start there.</p>
  </section>

  <section class="max-page hairline-t hairline-b" style="padding:20px 24px">
    <div style="display:flex;gap:12px;overflow-x:auto;align-items:center">
      <span class="eyebrow" style="flex-shrink:0">Region</span>
      <button class="tab is-active">All regions</button>
      <button class="tab">North</button>
      <button class="tab">Central</button>
      <button class="tab">South</button>
      <button class="tab">Islands</button>
    </div>
  </section>

  <section class="max-page sec">
    <div style="display:grid;grid-template-columns:1fr;gap:48px">
      <!-- Big feature: Hoi An -->
      <a href="/cities/hoi-an/" class="city-card feat" style="aspect-ratio:auto;padding:48px;display:grid;grid-template-columns:1fr;gap:24px">
        <div>
          <div class="eyebrow acc">Featured · April 2026</div>
          <div class="city-name" style="font-size:clamp(56px,8vw,96px);margin-top:16px">Hoi An</div>
          <p class="muted" style="max-width:460px;margin-top:16px;font-size:16px">The lantern town. 48 answered questions spanning food, transport, culture, budget and where to stay — recently updated.</p>
        </div>
        <div class="ph-stripes" style="height:200px">[ hoi_an.editorial_illustration ]</div>
      </a>

      <div class="city-grid">
        {otherCities.map((c) => <CityCard {...c} lang="en" />)}
      </div>

      <div class="hairline-t" style="padding-top:32px">
        <div class="eyebrow" style="margin-bottom:8px">Coming soon</div>
        <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:16px">
          {comingSoon.map((name) => (
            <span class="chip" style="opacity:.6">{name}</span>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
