---
import BaseLayout from '@layouts/BaseLayout.astro';

const q = Astro.url.searchParams.get('q') || '';
---

<BaseLayout
  title={q ? `Search: ${q} — Pholio` : 'Search — Pholio'}
  description="Search all answered questions about traveling Vietnam."
  lang="en"
  schemaType="WebSite"
>
  <section class="max-page" style="padding-top:64px;padding-bottom:96px">
    <div class="eyebrow" style="margin-bottom:16px">Search</div>

    {/* Pagefind UI renders here */}
    <div id="search"></div>

    <noscript>
      <form method="get" action="/search/" class="search-wrap" role="search" style="margin-top:24px">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
        </svg>
        <input class="search-input" type="search" name="q" value={q} placeholder="Search questions…"/>
      </form>
      <p class="muted" style="margin-top:16px;font-size:14px">Enable JavaScript for full search.</p>
    </noscript>
  </section>
</BaseLayout>

{/* Pagefind styles — loaded from /pagefind/ (generated at build time) */}
<link href="/pagefind/pagefind-ui.css" rel="stylesheet"/>

<style>
  /* Override Pagefind UI to match Pholio design system */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #C2410C;
    --pagefind-ui-text: #1A1613;
    --pagefind-ui-background: #FAF8F3;
    --pagefind-ui-border: #E8E2D5;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 2px;
    --pagefind-ui-font: 'Inter', system-ui, sans-serif;
    --pagefind-ui-message-background: #FAF8F3;
    --pagefind-ui-tag: #FEF3EC;
  }

  /* Search input matches site search-input style */
  .pagefind-ui__search-input {
    font-family: 'Bona Nova SC', Georgia, serif !important;
    font-size: 24px !important;
    font-style: italic;
    border: none !important;
    border-bottom: 2px solid #1A1613 !important;
    border-radius: 0 !important;
    background: transparent !important;
    padding: 8px 0 16px !important;
    color: #1A1613;
    width: 100%;
  }

  .pagefind-ui__search-input::placeholder {
    color: #6B6259;
  }

  /* Remove default search button */
  .pagefind-ui__search-clear {
    right: 0;
  }

  /* Results */
  .pagefind-ui__results-area {
    margin-top: 48px;
  }

  .pagefind-ui__message {
    font-size: 14px;
    color: #6B6259;
    margin-bottom: 32px;
    font-family: 'Inter', sans-serif;
    letter-spacing: .08em;
    text-transform: uppercase;
    font-size: 12px;
  }

  .pagefind-ui__result {
    border-top: 1px solid #E8E2D5;
    padding: 28px 0;
    border-bottom: none;
  }

  .pagefind-ui__result-title {
    font-family: 'Bona Nova SC', Georgia, serif;
    font-size: 24px;
    line-height: 1.2;
    font-weight: 400;
    margin-bottom: 8px;
  }

  .pagefind-ui__result-title a {
    color: #1A1613;
    text-decoration: none;
  }

  .pagefind-ui__result-title a:hover {
    color: #C2410C;
  }

  .pagefind-ui__result-excerpt {
    font-size: 15px;
    color: #6B6259;
    line-height: 1.6;
    margin: 0;
  }

  /* Highlight matches */
  mark {
    background: #FEF3EC;
    color: #C2410C;
    padding: 0 2px;
  }

  /* Load more button */
  .pagefind-ui__button {
    background: transparent;
    color: #1A1613;
    border: 1px solid #1A1613;
    border-radius: 2px;
    padding: 12px 22px;
    font-size: 14px;
    cursor: pointer;
    margin-top: 32px;
    font-family: 'Inter', sans-serif;
    transition: background .15s, color .15s;
  }

  .pagefind-ui__button:hover {
    background: #1A1613;
    color: #FAF8F3;
  }

  /* Filter tags (categories) */
  .pagefind-ui__filter-panel {
    margin-top: 24px;
  }
</style>

<script define:vars={{ q }}>
  // Load Pagefind UI after DOM ready
  async function initSearch() {
    const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
    
    new PagefindUI({
      element: '#search',
      baseUrl: '/',
      pageSize: 10,
      showImages: false,
      showEmptyFilters: false,
      resetStyles: false,
      translations: {
        placeholder: 'Search questions about Vietnam travel…',
        zero_results: 'No results for [SEARCH_TERM]. Try a different keyword.',
        many_results: '[COUNT] results for [SEARCH_TERM]',
        one_result: '1 result for [SEARCH_TERM]',
        alt_search: 'No results for [SEARCH_TERM]. Showing results for [DIFFERENT_TERM] instead.',
        search_suggestion: 'No results for [SEARCH_TERM]. Try one of the following searches:',
        searching: 'Searching…',
      },
    });

    // Auto-search if query in URL
    if (q) {
      // Wait for PagefindUI to render then set value
      setTimeout(() => {
        const input = document.querySelector('.pagefind-ui__search-input');
        if (input) {
          input.value = q;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }, 100);
    }
  }

  // Init on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearch);
  } else {
    initSearch();
  }
</script>
