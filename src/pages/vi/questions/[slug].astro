---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import AnswerBox from '@components/AnswerBox.astro';
import QuestionCard from '@components/QuestionCard.astro';

export async function getStaticPaths() {
  const allQuestions = await getCollection('questions', ({ data, id }) => {
    return !data.draft && id.startsWith('vi/');
  });

  return allQuestions.map((entry) => ({
    params: { slug: entry.data.canonicalSlug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'questions'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { data } = entry;

const categoryLabels: Record<string, string> = {
  food: 'Ẩm thực',
  transport: 'Di chuyển',
  culture: 'Văn hoá',
  weather: 'Thời tiết',
  budget: 'Chi phí',
  safety: 'An toàn',
  planning: 'Lên kế hoạch',
  activities: 'Hoạt động',
  accommodation: 'Chỗ ở',
};

const allQuestions = await getCollection('questions', ({ data: d, id }) => {
  return !d.draft && id.startsWith('vi/') && d.city === data.city && d.canonicalSlug !== data.canonicalSlug;
});
const related = allQuestions.slice(0, 3);
---

<BaseLayout
  title={data.title}
  description={data.description}
  lang="vi"
  canonicalSlug={data.canonicalSlug}
  schemaType="Article"
  pubDate={data.pubDate}
  updatedDate={data.updatedDate}
  author={data.author}
  image={data.heroImage}
  faq={data.faq}
  keywords={data.keywords}
>
  <article class="max-page" style="padding-top:48px;padding-bottom:96px">
    <nav class="crumb" aria-label="Breadcrumb" style="margin-bottom:32px">
      <a href="/vi/">Việt Nam</a>
      <span class="sep">/</span>
      <a href={`/vi/cities/${data.city}/`}>{data.cityDisplay}</a>
      <span class="sep">/</span>
      <span class="cur">{categoryLabels[data.category]}</span>
    </nav>

    <div class="max-prose">
      <header style="margin-bottom:48px">
        <div class="cat-tag" style="margin-bottom:16px">{categoryLabels[data.category]}</div>
        <h1 style="font-size:clamp(36px,5vw,56px);line-height:1.1;letter-spacing:-.015em;margin-bottom:24px">
          {data.title}
        </h1>
        <div class="muted" style="display:flex;gap:16px;flex-wrap:wrap;font-size:14px">
          <span>
            <time datetime={data.pubDate.toISOString()}>
              {data.pubDate.toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
          </span>
          {data.updatedDate && (
            <span>
              · Cập nhật <time datetime={data.updatedDate.toISOString()}>
                {data.updatedDate.toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
            </span>
          )}
          <span>· đọc {data.readingTime} phút</span>
          {data.contributors.length > 0 && (
            <span>· Đóng góp bởi {data.contributors.length} người địa phương</span>
          )}
        </div>
      </header>

      <AnswerBox lang="vi">
        <Fragment set:html={data.quickAnswer} />
      </AnswerBox>

      <div class="prose-ed" style="margin-top:48px">
        <Content />
      </div>

      <aside class="callout" style="margin-top:56px;background:var(--warmpaper)">
        <div class="eyebrow" style="margin-bottom:8px">§ Trong ứng dụng</div>
        <p style="font-family:'Instrument Serif',Georgia,serif;font-size:22px;line-height:1.3;margin:0 0 16px">
          Lưu câu trả lời này offline, kèm bản đồ, địa chỉ và ghi chú địa phương.
        </p>
        <a href="/vi/app/" class="btn btn-acc">Tải Pholio →</a>
      </aside>

      {data.faq && data.faq.length > 0 && (
        <section style="margin-top:80px">
          <h2 style="font-size:32px;margin-bottom:24px">Các câu liên quan</h2>
          {data.faq.map((item) => (
            <details>
              <summary>
                <span>{item.q}</span>
                <span class="plus" aria-hidden="true"></span>
              </summary>
              <div class="answer" set:html={item.a} />
            </details>
          ))}
        </section>
      )}
    </div>

    {related.length > 0 && (
      <section style="margin-top:96px;padding-top:48px;border-top:1px solid var(--border)">
        <div class="eyebrow" style="margin-bottom:24px">Thêm về {data.cityDisplay}</div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:0 64px">
          {related.map((r) => (
            <QuestionCard
              href={`/vi/questions/${r.data.canonicalSlug}/`}
              category={categoryLabels[r.data.category]}
              city={r.data.cityDisplay}
              readingTime={r.data.readingTime}
              title={r.data.title}
              preview={r.data.description}
              variant="grid"
            />
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
