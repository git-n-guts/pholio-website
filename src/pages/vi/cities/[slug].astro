---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const cities = await getCollection('cities');
  return cities.map((city) => ({
    params: { slug: city.id },
    props: { city },
  }));
}

interface Props {
  city: CollectionEntry<'cities'>;
}

const { city } = Astro.props;
const { data } = city;
const citySlug = city.id;

const categoryLabels: Record<string, string> = {
  food: 'Ẩm thực', transport: 'Di chuyển', culture: 'Văn hoá', weather: 'Thời tiết',
  budget: 'Chi phí', safety: 'An toàn', planning: 'Lên kế hoạch',
  activities: 'Hoạt động', accommodation: 'Chỗ ở',
};

const questions = await getCollection('questions', ({ data: d, id }) => {
  return !d.draft && id.startsWith('vi/') && d.city === citySlug;
});

const byCategory = questions.reduce<Record<string, typeof questions>>((acc, q) => {
  if (!acc[q.data.category]) acc[q.data.category] = [];
  acc[q.data.category].push(q);
  return acc;
}, {});

const categoryOrder = ['food', 'transport', 'culture', 'accommodation', 'activities', 'budget', 'safety', 'weather', 'planning'];
const orderedCategories = categoryOrder.filter((c) => byCategory[c]);

const categoryDescriptions: Record<string, string> = {
  food: 'Người địa phương ăn gì, tìm phiên bản thật ở đâu, và bỏ qua gì. Cập nhật hàng tuần.',
  transport: 'Làm sao đến, đi lại ra sao, và tránh bị chặt chém ở bến taxi.',
  culture: 'Lồng đèn, lễ hội, thợ may phố cổ, và những gì không nên chụp ảnh.',
  budget: 'Chi phí một ngày thực tế và giá cả bạn nên expect.',
  accommodation: 'Ở đâu, theo khu và phong cách du lịch.',
  activities: 'Những gì đáng làm, và những gì bị bán quá giá.',
  safety: 'Các vấn đề thực tế và đánh giá rủi ro trung thực.',
  weather: 'Hướng dẫn đi theo tháng.',
  planning: 'Lịch trình và các quyết định logistic.',
};
---

<BaseLayout
  title={`${data.name} — Pholio`}
  description={data.description}
  lang="vi"
  canonicalSlug={`cities-${citySlug}`}
  schemaType="CollectionPage"
  keywords={[`${data.name} du lịch`, `hướng dẫn ${data.name}`]}
>
  <section class="max-page" style="padding-top:64px;padding-bottom:48px">
    <nav class="crumb">
      <a href="/vi/">VIỆT NAM</a>
      <span class="sep">→</span>
      <a href="/vi/cities/">{data.region.toUpperCase()}</a>
      <span class="sep">→</span>
      <span class="cur">{data.name.toUpperCase()}</span>
    </nav>
    <h1 class="city-display" style="margin-top:24px">{data.name}<span class="acc">.</span></h1>
    <p style="font-family:var(--font-heading);font-size:clamp(24px,3vw,36px);line-height:1.2;color:var(--muted);max-width:780px;font-style:italic;margin-top:24px">
      {data.tagline}
    </p>

    <div class="facts-grid">
      {data.bestSeason && (
        <div class="fact-cell">
          <div class="eyebrow" style="margin-bottom:8px">Mùa đẹp nhất</div>
          <div style="font-family:var(--font-heading);font-size:24px">{data.bestSeason}</div>
          <div class="muted" style="font-size:12px;margin-top:4px">Khô, ấm, độ ẩm thấp</div>
        </div>
      )}
      {data.daysRecommended && (
        <div class="fact-cell">
          <div class="eyebrow" style="margin-bottom:8px">Số ngày nên đi</div>
          <div style="font-family:var(--font-heading);font-size:24px">{data.daysRecommended}</div>
          <div class="muted" style="font-size:12px;margin-top:4px">3 ngày là vừa đủ</div>
        </div>
      )}
      {data.budgetLevel && (
        <div class="fact-cell">
          <div class="eyebrow" style="margin-bottom:8px">Mức chi tiêu</div>
          <div style="font-family:var(--font-heading);font-size:24px;text-transform:capitalize">{data.budgetLevel.replace('-', ' ')}</div>
          <div class="muted" style="font-size:12px;margin-top:4px">≈ ₫1,8 triệu/ngày</div>
        </div>
      )}
      <div class="fact-cell">
        <div class="eyebrow" style="margin-bottom:8px">Câu đã trả lời</div>
        <div style="font-family:var(--font-heading);font-size:24px">{questions.length}</div>
        <div class="muted" style="font-size:12px;margin-top:4px">{orderedCategories.length} chuyên mục</div>
      </div>
    </div>
  </section>

  <div class="max-page" style="padding-bottom:80px">
    <div class="ph-stripes" style="width:100%;height:280px;border:1px solid var(--border)">
      [ map · {citySlug}.editorial_illustration ]
    </div>
  </div>

  <section class="max-page hairline-t hairline-b" style="position:sticky;top:68px;background:var(--bg);z-index:30;padding-top:20px;padding-bottom:20px">
    <div style="display:flex;gap:12px;overflow-x:auto;align-items:center">
      <span class="eyebrow" style="flex-shrink:0;margin-right:8px">Lọc</span>
      <button class="tab is-active">Tất cả · {questions.length}</button>
      {orderedCategories.map((cat) => (
        <a href={`/vi/categories/${cat}/`} class="tab">{categoryLabels[cat]} · {byCategory[cat].length}</a>
      ))}
    </div>
  </section>

  <section class="max-page sec">
    {questions.length === 0 ? (
      <div style="max-width:680px;padding:48px 0">
        <p class="muted" style="font-size:18px">Chưa có câu hỏi nào về {data.name}. <a href="/vi/ask/" class="ulink">Hãy hỏi?</a></p>
      </div>
    ) : (
      orderedCategories.map((cat) => (
        <div style="margin-bottom:80px">
          <div class="cat-head">
            <div>
              <div class="eyebrow acc" style="margin-bottom:8px">Chuyên mục</div>
              <h2 style="font-size:40px;line-height:1">{categoryLabels[cat]}<span class="muted">.</span></h2>
              <div class="muted" style="font-size:14px;margin-top:8px">{byCategory[cat].length} câu hỏi</div>
            </div>
            <div class="muted" style="max-width:560px">{categoryDescriptions[cat]}</div>
          </div>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:0 64px">
            {byCategory[cat].map((q) => (
              <a href={`/vi/questions/${q.data.city}/${q.data.canonicalSlug}/`} class="q-card">
                <div class="meta">
                  <span class="cat-tag">{categoryLabels[cat]}</span>
                  <span class="muted" style="font-size:12px">{q.data.readingTime} phút</span>
                </div>
                <h3 style="font-size:24px;line-height:1.2;margin-bottom:8px">{q.data.title}</h3>
                <p class="muted" style="font-size:14px;margin:0">{q.data.description}</p>
              </a>
            ))}
          </div>
          {byCategory[cat].length >= 4 && (
            <div class="hairline-t" style="margin-top:32px;padding-top:32px">
              <a href={`/vi/categories/${cat}/`} class="ulink" style="font-size:14px">Xem tất cả {byCategory[cat].length} câu hỏi {categoryLabels[cat].toLowerCase()} →</a>
            </div>
          )}
        </div>
      ))
    )}
  </section>

  <div class="rule"></div>

  <section class="max-page sec">
    <div style="display:grid;grid-template-columns:1fr;gap:48px;align-items:end" class="app-grid-city">
      <div style="max-width:720px">
        <div class="eyebrow" style="margin-bottom:16px">§ · Ứng dụng</div>
        <h2 style="font-family:var(--font-heading);font-size:clamp(36px,6vw,60px);line-height:1.02">Đem {data.name} <em>offline.</em></h2>
        <p class="muted" style="font-size:18px;margin-top:24px;max-width:520px">
          Tải pack {data.name} — mọi câu hỏi đã trả lời, kèm bản đồ, địa chỉ, giờ mở cửa, cache offline.
        </p>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:12px">
        <a href="/vi/app/" class="store-badge"><span style="display:flex;flex-direction:column"><span class="sub">Tải từ</span><span class="main">App Store</span></span></a>
        <a href="/vi/app/" class="store-badge alt"><span style="display:flex;flex-direction:column"><span class="sub">Tải từ</span><span class="main">Google Play</span></span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .facts-grid {
    margin-top: 64px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
  }
  @media (min-width: 768px) {
    .facts-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .fact-cell {
    background: var(--bg);
    padding: 24px;
  }
  .cat-head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-bottom: 24px;
    align-items: baseline;
  }
  @media (min-width: 768px) {
    .cat-head {
      grid-template-columns: 200px 1fr;
    }
  }
  .app-grid-city {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }
  @media (min-width: 900px) {
    .app-grid-city {
      grid-template-columns: 1fr auto;
    }
  }
</style>
