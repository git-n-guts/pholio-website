---
// TODO-VI: review translation và pricing nếu dùng VND
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Ứng dụng Pholio — Mọi câu trả lời, offline, trong túi bạn"
  description="Tải Pholio cho iOS và Android. City pack offline, hỏi người địa phương, từ điển giao tiếp có audio."
  lang="vi"
  schemaType="WebSite"
>
  <section class="max-page ptitle" style="padding-bottom:80px">
    <div class="eyebrow" style="margin-top:24px">Pholio cho iOS &amp; Android</div>
    <h1 class="hero-h1" style="margin-top:16px">Mọi câu trả lời,<br/><em>trong túi bạn. Offline.</em></h1>
    <p class="muted" style="max-width:560px;margin-top:24px;font-size:18px">Tải city pack trước khi đi. Không cần data roaming, không cần Wi-Fi khách sạn chập chờn, không phải lật tung Wi-Fi để check giờ mở cửa.</p>
    <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:40px">
      <a href="#" class="store-badge"><span style="display:flex;flex-direction:column"><span class="sub">Tải về từ</span><span class="main">App Store</span></span></a>
      <a href="#" class="store-badge alt"><span style="display:flex;flex-direction:column"><span class="sub">Tải về từ</span><span class="main">Google Play</span></span></a>
    </div>
  </section>

  <section class="max-page" style="padding-bottom:96px">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px">
      <div class="ph-stripes" style="aspect-ratio:9/19">[ screen.home ]</div>
      <div class="ph-stripes" style="aspect-ratio:9/19">[ screen.answer ]</div>
      <div class="ph-stripes" style="aspect-ratio:9/19">[ screen.map ]</div>
      <div class="ph-stripes" style="aspect-ratio:9/19">[ screen.ask_local ]</div>
    </div>
  </section>

  <div class="rule"></div>

  <section class="max-page sec">
    <div class="sec-head">
      <div class="eyebrow" style="margin-bottom:16px">§ · Chức năng</div>
      <h2 class="display-h2">Bốn việc, làm đến nơi.</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:48px 64px">
      <div><div class="mono muted" style="font-size:12px;margin-bottom:16px">01</div><h3 style="font-size:28px;line-height:1.15;margin-bottom:12px">City pack offline</h3><p class="muted" style="font-size:15px;margin:0">Tải Hội An, Hà Nội, hoặc Sài Gòn — câu hỏi, bản đồ, địa chỉ, giờ mở cửa, đều cache sẵn.</p></div>
      <div><div class="mono muted" style="font-size:12px;margin-bottom:16px">02</div><h3 style="font-size:28px;line-height:1.15;margin-bottom:12px">Hỏi người địa phương</h3><p class="muted" style="font-size:15px;margin:0">Không tìm thấy câu hỏi đã trả lời? Gửi cho cộng tác viên thật. Phản hồi trung bình 18 giờ.</p></div>
      <div><div class="mono muted" style="font-size:12px;margin-bottom:16px">03</div><h3 style="font-size:28px;line-height:1.15;margin-bottom:12px">Từ điển giao tiếp có audio</h3><p class="muted" style="font-size:15px;margin:0">Phát âm chuẩn tiếng Việt cho 200+ câu giao tiếp du lịch. Hoạt động offline.</p></div>
      <div><div class="mono muted" style="font-size:12px;margin-bottom:16px">04</div><h3 style="font-size:28px;line-height:1.15;margin-bottom:12px">Câu trả lời đã lưu, đồng bộ</h3><p class="muted" style="font-size:15px;margin:0">Đánh dấu trên web, đọc trên máy bay. Đồng bộ giữa các thiết bị khi online.</p></div>
    </div>
  </section>

  <div class="rule"></div>

  <section class="max-page sec">
    <div class="sec-head">
      <div class="eyebrow" style="margin-bottom:16px">§ · Giá</div>
      <h2 class="display-h2">Đơn giản.</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1px;background:var(--border)">
      <div style="background:var(--bg);padding:40px">
        <div class="eyebrow" style="margin-bottom:16px">Miễn phí</div>
        <div style="font-family:'Instrument Serif',serif;font-size:56px;line-height:1">$0</div>
        <p class="muted" style="font-size:14px;margin:16px 0 24px">Đọc online mọi câu trả lời, lưu offline tối đa 10 câu.</p>
        <a href="#" class="btn btn-ghost" style="font-size:14px">Tải về →</a>
      </div>
      <div style="background:var(--warmpaper);padding:40px;position:relative">
        <div class="eyebrow acc" style="margin-bottom:16px">Traveler · phổ biến nhất</div>
        <div style="font-family:'Instrument Serif',serif;font-size:56px;line-height:1">$4.99<span class="muted" style="font-size:18px"> / tháng</span></div>
        <p class="muted" style="font-size:14px;margin:16px 0 24px">Không giới hạn pack offline, hỏi người địa phương, từ điển.</p>
        <a href="#" class="btn btn-acc" style="font-size:14px">Đăng ký →</a>
      </div>
      <div style="background:var(--bg);padding:40px">
        <div class="eyebrow" style="margin-bottom:16px">Theo năm</div>
        <div style="font-family:'Instrument Serif',serif;font-size:56px;line-height:1">$39<span class="muted" style="font-size:18px"> / năm</span></div>
        <p class="muted" style="font-size:14px;margin:16px 0 24px">Giống Traveler, trả một lần. Tiết kiệm hai tháng.</p>
        <a href="#" class="btn btn-ghost" style="font-size:14px">Đăng ký →</a>
      </div>
    </div>
  </section>
</BaseLayout>
