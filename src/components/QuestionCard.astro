---
interface Props {
  href: string;
  category: string;
  city: string;
  readingTime: number;
  title: string;
  preview?: string;
  date?: string; // format "Apr 21" for compact variant
  variant?: 'grid' | 'compact';
}

const {
  href,
  category,
  city,
  readingTime,
  title,
  preview,
  date,
  variant = 'grid',
} = Astro.props;
---

{variant === 'grid' ? (
  <a href={href} class="q-card">
    <div class="meta">
      <span class="cat-tag">{category}</span>
      <span class="muted" style="font-size:13px">{city} · {readingTime} min</span>
    </div>
    <h3 style="font-size:28px;line-height:1.15;margin-bottom:12px">{title}</h3>
    {preview && <p class="muted" style="font-size:15px;margin:0">{preview}</p>}
  </a>
) : (
  <a href={href} class="q-card" style="display:flex;align-items:flex-start;gap:24px;padding:20px 0">
    {date && (
      <span class="mono muted" style="font-size:12px;width:48px;padding-top:8px;flex-shrink:0">
        {date}
      </span>
    )}
    <div style="flex:1">
      <div class="cat-tag" style="margin-bottom:4px">{category} · {city}</div>
      <div style="font-family:'Instrument Serif',serif;font-size:22px;line-height:1.2">
        {title}
      </div>
    </div>
    <span class="muted" style="font-size:12px;padding-top:8px;flex-shrink:0">{readingTime} min</span>
  </a>
)}
